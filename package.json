{
  "name": "timboy",
  "version": "1.0.0",
  "description": "TimZ 個人網站 - TimBoy 風格的互動式作品集",
  "main": "index.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "dev:legacy": "npx live-server --host=0.0.0.0",
    "new-trip": "node tools/new-trip.js",
    "fetch:history": "node tools/fetch-cb-history.js",
    "fetch:history:full": "node tools/fetch-cb-history.js --all --smart --sync",
    "sync-cb": "python tools/xq_bridge.py --meta --dry-run",
    "sync:dde": "python tools/fetch-hot-cb-dde.py",
    "format": "npx prettier --write \"**/*.{html,css,js,md}\"",
    "test": "vitest run",
    "test:unit": "vitest run src/lib/cb_logic.test.mjs",
    "test:ui": "playwright test",
    "test:console": "playwright test tests/console-guard.spec.js",
    "guard": "node tools/guard/check-datapath.js && node tools/guard/verify-dom.js"
  },
  "keywords": [
    "portfolio",
    "landing-page",
    "trip-planner",
    "react"
  ],
  "author": "TimZ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foreverbule2003/me.git"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "dotenv": "^17.2.3",
    "firebase": "^12.7.0",
    "hammerjs": "^2.0.8",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "firebase-admin": "^13.6.0",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "puppeteer": "^24.35.0",
    "tailwindcss": "^4.1.18",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}